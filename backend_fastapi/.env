# SMTP (email verification)
# Пример для Gmail (App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your_email@gmail.com
# SMTP_STARTTLS=true
# SMTP_USE_SSL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
SMTP_USE_SSL=false

# Email code behavior
EMAIL_CODE_EXPIRES_SECONDS=300
EMAIL_CODE_LENGTH=6
# false = без SMTP регистрация по email-коду не пройдет
EMAIL_CODE_DEV_FALLBACK=false

