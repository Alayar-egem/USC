# Vercel frontend environment variables

# Required: public backend API base URL
VITE_API_BASE=https://your-backend.up.railway.app/api

# Optional map defaults
VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
VITE_MAP_DEFAULT_LAT=42.8746
VITE_MAP_DEFAULT_LNG=74.5698
VITE_MAP_DEFAULT_ZOOM=12

# Optional observability
VITE_SENTRY_DSN_FRONTEND=
VITE_SENTRY_ENVIRONMENT=vercel
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
