# Vercel backend (Python Function) environment variables

# Required
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
REDIS_URL=redis://default:PASSWORD@HOST:6379
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
API_PREFIX=/api

# Replace with your exact Vercel frontend URL
CORS_ALLOW_ORIGINS=https://your-frontend.vercel.app

# Optional CORS regex
CORS_ALLOW_ORIGIN_REGEX=

# Optional runtime flags
EMAIL_CODE_DEV_FALLBACK=true
AUTO_SEED_DEMO=false
METRICS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_CLOSED=false

# Optional SMTP (required for real email verification in production)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
SMTP_USE_SSL=false

# Optional observability
SENTRY_DSN_BACKEND=
SENTRY_ENVIRONMENT=vercel
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
